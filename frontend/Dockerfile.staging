FROM node:20-slim

WORKDIR /app

# Install dependencies (use lockfile for reproducibility)
COPY package*.json ./
RUN npm ci --legacy-peer-deps

# Expose Vite dev server port
EXPOSE 3334

# Default command (overridable by docker-compose)
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3334"]
